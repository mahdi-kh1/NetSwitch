<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AssemblyName>NetSwitch</AssemblyName>
    <RootNamespace>NetSwitch</RootNamespace>
    <Version>0.1.2</Version>
    <Product>NetSwitch</Product>
    <Description>Tray app to switch between Wi-Fi and Ethernet</Description>
    <Authors>mikhodaee@gmail.com</Authors>
    <Company>mikhodaee@gmail.com</Company>
    <Copyright>Developed by mikhodaee@gmail.com</Copyright>
    <ApplicationIcon>Assets\app.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Hardcodet.NotifyIcon.Wpf" Version="2.0.1" />
    <PackageReference Include="System.Management" Version="10.0.9" />
  </ItemGroup>

  <ItemGroup>
    <None Update="Assets\app.ico">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
