<Window x:Class="NetSwitch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NetSwitch"
        mc:Ignorable="d"
        Title="NetSwitch"
        Width="380" Height="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <Style x:Key="IconBtn" TargetType="Button" BasedOn="{StaticResource GlassButton}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="15" />
        </Style>
    </Window.Resources>

    <!-- Outer rounded glass shell -->
    <Border CornerRadius="22" Background="{StaticResource WindowBackdropBrush}"
            BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />   <!-- header -->
                <RowDefinition Height="Auto" />   <!-- hero status -->
                <RowDefinition Height="Auto" />   <!-- section label -->
                <RowDefinition Height="Auto" />   <!-- switch tiles -->
                <RowDefinition Height="Auto" />   <!-- auto mode -->
                <RowDefinition Height="*" />      <!-- spacer -->
                <RowDefinition Height="Auto" />   <!-- footer -->
            </Grid.RowDefinitions>

            <!-- ===== HEADER ===== -->
            <Grid Grid.Row="0" MouseLeftButtonDown="Header_DragMove">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="38" Height="38" CornerRadius="11"
                            Background="{StaticResource GlassActiveBrush}"
                            BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1">
                        <TextBlock Text="&#xE701;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="18"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="NetSwitch" Style="{StaticResource TitleText}" FontSize="18" />
                        <TextBlock Text="Network switcher" Style="{StaticResource LabelText}" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button x:Name="RefreshBtn" Style="{StaticResource IconBtn}" Content="&#xE72C;"
                            Click="Refresh_Click" ToolTip="Refresh status" Margin="0,0,8,0" />
                    <Button x:Name="CloseBtn" Style="{StaticResource IconBtn}" Content="&#xE711;"
                            Click="Close_Click" ToolTip="Hide to tray" />
                </StackPanel>
            </Grid>

            <!-- ===== HERO STATUS CARD ===== -->
            <Border Grid.Row="1" Margin="0,18,0,0" CornerRadius="20" Padding="18"
                    Background="{StaticResource HeroBrush}"
                    BorderBrush="{StaticResource GlassActiveBorderBrush}" BorderThickness="1">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="ACTIVE CONNECTION" Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="11" FontWeight="SemiBold" />
                        <TextBlock x:Name="ActiveName" Text="Ethernet" Foreground="White"
                                   FontSize="26" FontWeight="Bold" Margin="0,4,0,0" />
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Ellipse Width="9" Height="9" Fill="White" VerticalAlignment="Center" />
                            <TextBlock x:Name="ActiveStatus" Text="Connected" Foreground="White"
                                       FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="&#xE839;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               Foreground="#66FFFFFF" FontSize="56"
                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- ===== SECTION LABEL ===== -->
            <TextBlock Grid.Row="2" Text="Switch to" Style="{StaticResource ValueText}"
                       Margin="2,22,0,0" />

            <!-- ===== SWITCH TILES ===== -->
            <Grid Grid.Row="3" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button x:Name="WifiTile" Grid.Column="0" Height="110"
                        Style="{StaticResource GlassButton}" Click="SwitchWifi_Click">
                    <StackPanel>
                        <TextBlock Text="&#xE701;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="30" HorizontalAlignment="Center"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Wi-Fi" FontSize="15" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,10,0,0"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock x:Name="WifiSub" Text="Off" Style="{StaticResource LabelText}"
                                   HorizontalAlignment="Center" Margin="0,2,0,0" />
                    </StackPanel>
                </Button>

                <Button x:Name="EthTile" Grid.Column="2" Height="110"
                        Style="{StaticResource GlassButton}" Click="SwitchEthernet_Click">
                    <StackPanel>
                        <TextBlock Text="&#xE839;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="30" HorizontalAlignment="Center"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Ethernet" FontSize="15" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,10,0,0"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock x:Name="EthSub" Text="Connected" Style="{StaticResource LabelText}"
                                   HorizontalAlignment="Center" Margin="0,2,0,0" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- ===== AUTO MODE ===== -->
            <Border Grid.Row="4" Margin="0,12,0,0" Style="{StaticResource GlassCard}" Padding="16,12">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Auto switch" Style="{StaticResource ValueText}" />
                        <TextBlock Text="Prefer Ethernet when cable is plugged"
                                   Style="{StaticResource LabelText}" Margin="0,2,0,0" />
                    </StackPanel>
                    <CheckBox x:Name="AutoToggle" Style="{StaticResource ToggleSwitch}"
                              HorizontalAlignment="Right" VerticalAlignment="Center"
                              Checked="Auto_Changed" Unchecked="Auto_Changed" />
                </Grid>
            </Border>

            <!-- ===== FOOTER ===== -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Height="44" Style="{StaticResource GlassButton}"
                        Click="Settings_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="15" VerticalAlignment="Center" />
                        <TextBlock Text="Settings" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Width="44" Height="44" Style="{StaticResource IconBtn}"
                        Content="&#xE7E8;" Click="Quit_Click" ToolTip="Quit NetSwitch" />
            </Grid>
        </Grid>
    </Border>
</Window>
