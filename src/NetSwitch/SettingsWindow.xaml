<Window x:Class="NetSwitch.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="NetSwitch Settings"
        Width="430" Height="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="IconBtn" TargetType="Button" BasedOn="{StaticResource GlassButton}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <!-- Adapter row template for the combo -->
        <DataTemplate x:Key="AdapterItemTemplate">
            <StackPanel>
                <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="14" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Border CornerRadius="22" Background="{StaticResource WindowBackdropBrush}"
            BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1">
        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0" MouseLeftButtonDown="Header_DragMove">
                <StackPanel>
                    <TextBlock Text="Settings" Style="{StaticResource TitleText}" />
                    <TextBlock Text="Configure adapters and behavior" Style="{StaticResource LabelText}" />
                </StackPanel>
                <Button x:Name="CloseBtn" Style="{StaticResource IconBtn}" Content="&#xE711;"
                        HorizontalAlignment="Right" VerticalAlignment="Top" Click="Cancel_Click" />
            </Grid>

            <!-- BODY -->
            <StackPanel Grid.Row="1" Margin="0,20,0,0">

                <TextBlock Text="ADAPTERS" Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" FontWeight="SemiBold" Margin="2,0,0,8" />

                <Border Style="{StaticResource GlassCard}" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="&#xE701;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Wi-Fi adapter" Style="{StaticResource ValueText}"
                                       Margin="8,0,0,0" />
                        </StackPanel>
                        <ComboBox x:Name="WifiCombo" Style="{StaticResource GlassCombo}"
                                  ItemTemplate="{StaticResource AdapterItemTemplate}" />

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,6">
                            <TextBlock Text="&#xE839;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Ethernet adapter" Style="{StaticResource ValueText}"
                                       Margin="8,0,0,0" />
                        </StackPanel>
                        <ComboBox x:Name="EthCombo" Style="{StaticResource GlassCombo}"
                                  ItemTemplate="{StaticResource AdapterItemTemplate}" />

                        <Button x:Name="RefreshBtn" Height="34" Margin="0,14,0,0"
                                Style="{StaticResource GlassButton}" Click="Refresh_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="13" VerticalAlignment="Center" />
                                <TextBlock Text="Refresh adapters" Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <TextBlock Text="BEHAVIOR" Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" FontWeight="SemiBold" Margin="2,20,0,8" />

                <Border Style="{StaticResource GlassCard}" Padding="16,6">
                    <StackPanel>
                        <Grid Margin="0,10">
                            <StackPanel VerticalAlignment="Center" Margin="0,0,52,0">
                                <TextBlock Text="Disable the other adapter" Style="{StaticResource ValueText}" />
                                <TextBlock Text="Turn the opposite adapter off when switching"
                                           Style="{StaticResource LabelText}" TextWrapping="Wrap" Margin="0,2,0,0" />
                            </StackPanel>
                            <CheckBox x:Name="DisableOppositeToggle" Style="{StaticResource ToggleSwitch}"
                                      HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="#1AFFFFFF" />

                        <Grid Margin="0,10">
                            <StackPanel VerticalAlignment="Center" Margin="0,0,52,0">
                                <TextBlock Text="Auto switch" Style="{StaticResource ValueText}" />
                                <TextBlock Text="Prefer Ethernet while a cable is connected"
                                           Style="{StaticResource LabelText}" TextWrapping="Wrap" Margin="0,2,0,0" />
                            </StackPanel>
                            <CheckBox x:Name="AutoToggle" Style="{StaticResource ToggleSwitch}"
                                      HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="#1AFFFFFF" />

                        <Grid Margin="0,10">
                            <StackPanel VerticalAlignment="Center" Margin="0,0,52,0">
                                <TextBlock Text="Start with Windows" Style="{StaticResource ValueText}" />
                                <TextBlock Text="Launch automatically at sign-in"
                                           Style="{StaticResource LabelText}" TextWrapping="Wrap" Margin="0,2,0,0" />
                            </StackPanel>
                            <CheckBox x:Name="StartupToggle" Style="{StaticResource ToggleSwitch}"
                                      HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- FOOTER -->
            <Grid Grid.Row="2" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Height="46" Content="Cancel"
                        Style="{StaticResource GlassButton}" Click="Cancel_Click" />
                <Button Grid.Column="2" Height="46" Content="Save"
                        Style="{StaticResource AccentButton}" Click="Save_Click" />
            </Grid>
        </Grid>
    </Border>
</Window>
